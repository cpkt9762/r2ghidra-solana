--- /dev/null
+++ b/src/Processors/sBPF/data/languages/sBPF_v3.sinc
@@ -0,0 +1,291 @@
+###############################################################################
+# sBPF Processor Specification for Ghidra
+
+#sBPF is a RISC register machine with a total of 11 64-bit registers, a program counter and a 512 byte fixed-size stack.
+#9 registers are general purpouse read-write, one is a read-only stack pointer and the program counter is implicit,
+#i.e. we can only jump to a certain offset from it. The sBPF registers are always 64-bit wide.
+
+define space ram type=ram_space size=8 default;
+define space register type=register_space size=4;
+define space syscall type=ram_space size=4;
+
+define register offset=0 size=8 [ R0  R1  R2  R3  R4  R5  R6  R7  R8  R9  R10  PC ];
+
+# Instruction encoding: Insop:8, dst_reg:4, src_reg:4, off:16, imm:32 - from lsb to msb
+define token instr(64)
+	imm=(32, 63) signed
+	off=(16, 31) signed
+	src=(12, 15)
+	dst=(8, 11)
+	op_alu_jmp_opcode=(4, 7)
+	op_alu_jmp_source=(3, 3)
+	op_ld_st_mode=(5, 7)
+	op_ld_st_size=(3, 4)
+	op_insn_class=(0, 2)
+;
+
+#We'll need this token to operate with LDDW instruction, which has 64 bit imm value
+define token immtoken(64)
+	imm2=(32, 63)
+;
+
+#To operate with registers
+attach variables [ src dst ] [  R0  R1  R2  R3  R4  R5  R6  R7  R8  R9  R10  _  _  _  _  _  ];
+
+#Arithmetic instructions
+###############################################################################
+
+:MOV dst, src  is src & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=src; }
+:MOV dst, imm  is imm & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=imm; }
+
+# v3/v2 toolchains may use 32-bit ALU class for constant materialization.
+:MOV32 dst, src  is src & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(src:4); }
+:MOV32 dst, imm  is imm & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(imm:4); }
+:NEG32 dst  is dst & op_alu_jmp_opcode=0x8 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(-dst:4); }
+:ADD32 dst, src  is src & dst & op_alu_jmp_opcode=0x0 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 + src:4); }
+:ADD32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x0 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 + imm:4); }
+:SUB32 dst, src  is src & dst & op_alu_jmp_opcode=0x1 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 - src:4); }
+:SUB32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x1 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 - imm:4); }
+:OR32 dst, src   is src & dst & op_alu_jmp_opcode=0x4 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 | src:4); }
+:OR32 dst, imm   is imm & dst & op_alu_jmp_opcode=0x4 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 | imm:4); }
+:AND32 dst, src  is src & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 & src:4); }
+:AND32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 & imm:4); }
+:LSH32 dst, src  is src & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 << src:4); }
+:LSH32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 << imm:4); }
+:RSH32 dst, src  is src & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 >> src:4); }
+:RSH32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 >> imm:4); }
+:XOR32 dst, src  is src & dst & op_alu_jmp_opcode=0xa & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 ^ src:4); }
+:XOR32 dst, imm  is imm & dst & op_alu_jmp_opcode=0xa & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 ^ imm:4); }
+:ARSH32 dst, src is src & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(dst:4 s>> src:4); }
+:ARSH32 dst, imm is imm & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=0 & op_insn_class=0x4 { dst=zext(dst:4 s>> imm:4); }
+
+:ADD dst, src  is src & dst & op_alu_jmp_opcode=0x0 & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst + src; }
+:ADD dst, imm  is imm & dst & op_alu_jmp_opcode=0x0 & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst + imm; }
+
+:SUB dst, src  is src & dst & op_alu_jmp_opcode=0x1 & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst - src; }
+:SUB dst, imm  is imm & dst & op_alu_jmp_opcode=0x1 & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst - imm; }
+
+:OR dst, src  is src & dst & op_alu_jmp_opcode=0x4 & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst | src; }
+:OR dst, imm  is imm & dst & op_alu_jmp_opcode=0x4 & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst | imm; }
+
+:AND dst, src  is src & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst & src; }
+:AND dst, imm  is imm & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst & imm; }
+
+:LSH dst, src  is src & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst << src; }
+:LSH dst, imm  is imm & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst << imm; }
+
+:RSH dst, src  is src & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst >> src; }
+:RSH dst, imm  is imm & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst >> imm; }
+
+:XOR dst, src  is src & dst & op_alu_jmp_opcode=0xa & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst ^ src; }
+:XOR dst, imm  is imm & dst & op_alu_jmp_opcode=0xa & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst ^ imm; }
+
+# Solana toolchains may emit HOR64 (opcode 0xf7) for 64-bit constant construction.
+:HOR64 dst, imm  is imm & dst & op_alu_jmp_opcode=0xf & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst | (imm:8 << 32); }
+
+:ARSH dst, src  is src & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=1 & op_insn_class=0x7 { dst=dst s>> src; }
+:ARSH dst, imm  is imm & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=0 & op_insn_class=0x7 { dst=dst s>> imm; }
+
+# PQR instructions (SIMD-0174), all encoded in class 0x6.
+:LMUL32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x8 & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=zext(dst:4 * imm:4); }
+:LMUL32 dst, src  is src & dst & op_alu_jmp_opcode=0x8 & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=zext(dst:4 * src:4); }
+:LMUL64 dst, imm  is imm & dst & op_alu_jmp_opcode=0x9 & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=dst * imm; }
+:LMUL64 dst, src  is src & dst & op_alu_jmp_opcode=0x9 & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=dst * src; }
+
+:UHMUL64 dst, imm  is imm & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=0 & op_insn_class=0x6 {
+	local a:16 = zext(dst);
+	local b:16 = zext(imm:4);
+	local p:16 = a * b;
+	dst = p(8);
+}
+:UHMUL64 dst, src  is src & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=1 & op_insn_class=0x6 {
+	local a:16 = zext(dst);
+	local b:16 = zext(src);
+	local p:16 = a * b;
+	dst = p(8);
+}
+:SHMUL64 dst, imm  is imm & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=0 & op_insn_class=0x6 {
+	local a:16 = sext(dst);
+	local b:16 = sext(imm:4);
+	local p:16 = a * b;
+	dst = p(8);
+}
+:SHMUL64 dst, src  is src & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=1 & op_insn_class=0x6 {
+	local a:16 = sext(dst);
+	local b:16 = sext(src);
+	local p:16 = a * b;
+	dst = p(8);
+}
+
+:UDIV32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x4 & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=zext(dst:4 / imm:4); }
+:UDIV32 dst, src  is src & dst & op_alu_jmp_opcode=0x4 & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=zext(dst:4 / src:4); }
+:UDIV64 dst, imm  is imm & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=dst / zext(imm:4); }
+:UDIV64 dst, src  is src & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=dst / src; }
+
+:UREM32 dst, imm  is imm & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=zext(dst:4 % imm:4); }
+:UREM32 dst, src  is src & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=zext(dst:4 % src:4); }
+:UREM64 dst, imm  is imm & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=dst % zext(imm:4); }
+:UREM64 dst, src  is src & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=dst % src; }
+
+:SDIV32 dst, imm  is imm & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=zext(dst:4 s/ imm:4); }
+:SDIV32 dst, src  is src & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=zext(dst:4 s/ src:4); }
+:SDIV64 dst, imm  is imm & dst & op_alu_jmp_opcode=0xd & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=dst s/ imm; }
+:SDIV64 dst, src  is src & dst & op_alu_jmp_opcode=0xd & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=dst s/ src; }
+
+:SREM32 dst, imm  is imm & dst & op_alu_jmp_opcode=0xe & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=zext(dst:4 s% imm:4); }
+:SREM32 dst, src  is src & dst & op_alu_jmp_opcode=0xe & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=zext(dst:4 s% src:4); }
+:SREM64 dst, imm  is imm & dst & op_alu_jmp_opcode=0xf & op_alu_jmp_source=0 & op_insn_class=0x6 { dst=dst s% imm; }
+:SREM64 dst, src  is src & dst & op_alu_jmp_opcode=0xf & op_alu_jmp_source=1 & op_insn_class=0x6 { dst=dst s% src; }
+
+#Byteswap instructions
+###############################################################################
+
+:BE16 dst  is imm=0x10 & dst & op_alu_jmp_opcode=0xd & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=((dst) >> 8) | ((dst) << 8); }
+:BE32 dst  is imm=0x20 & dst & op_alu_jmp_opcode=0xd & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=((dst) >> 24) | (((dst) & 0x00FF0000) >> 8)  | (((dst) & 0x0000FF00) << 8) | ((dst) << 24); }
+:BE64 dst  is imm=0x40 & dst & op_alu_jmp_opcode=0xd & op_alu_jmp_source=1 & op_insn_class=0x4 {
+		dst=( (dst << 56) & 0xff00000000000000 ) |
+		( (dst << 40) & 0x00ff000000000000 ) |
+		( (dst << 24) & 0x0000ff0000000000 ) |
+		( (dst <<  8) & 0x000000ff00000000 ) |
+		( (dst >>  8) & 0x00000000ff000000 ) |
+		( (dst >> 24) & 0x0000000000ff0000 ) |
+		( (dst >> 40) & 0x000000000000ff00 ) |
+		( (dst >> 56) & 0x00000000000000ff );
+}
+
+#Memory instructions- Load and Store
+###############################################################################
+
+# V3 remapped memory opcodes (SIMD-0173).
+:STB [dst + off], imm   is imm & off & dst & op_alu_jmp_opcode=0x2 & op_alu_jmp_source=0 & op_insn_class=0x7 { *:1 (dst + off)=imm:1; }
+:LDXB dst, [src + off]  is off & src & dst & op_alu_jmp_opcode=0x2 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(*:1 (src + off)); }
+:STXB [dst + off], src  is off & src & dst & op_alu_jmp_opcode=0x2 & op_alu_jmp_source=1 & op_insn_class=0x7 { *:1 (dst + off)=src:1; }
+
+:STH [dst + off], imm   is imm & off & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=0 & op_insn_class=0x7 { *:2 (dst + off)=imm:2; }
+:LDXH dst, [src + off]  is off & src & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(*:2 (src + off)); }
+:STXH [dst + off], src  is off & src & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=1 & op_insn_class=0x7 { *:2 (dst + off)=src:2; }
+
+:STW [dst + off], imm   is imm & off & dst & op_alu_jmp_opcode=0x8 & op_alu_jmp_source=0 & op_insn_class=0x7 { *:4 (dst + off)=imm:4; }
+:LDXW dst, [src + off]  is off & src & dst & op_alu_jmp_opcode=0x8 & op_alu_jmp_source=1 & op_insn_class=0x4 { dst=zext(*:4 (src + off)); }
+:STXW [dst + off], src  is off & src & dst & op_alu_jmp_opcode=0x8 & op_alu_jmp_source=1 & op_insn_class=0x7 { *:4 (dst + off)=src:4; }
+
+:STQ [dst + off], imm   is imm & off & dst & op_alu_jmp_opcode=0x9 & op_alu_jmp_source=0 & op_insn_class=0x7 { *:8 (dst + off)=imm:8; }
+:LDXQ dst, [src + off]  is off & src & dst & op_ld_st_mode=0x4 & op_ld_st_size=0x3 & op_insn_class=0x4 { dst=*:8 (src + off); }
+:STXQ [dst + off], src  is off & src & dst & op_ld_st_mode=0x4 & op_ld_st_size=0x3 & op_insn_class=0x7 { *:8 (dst + off)=src:8; }
+
+#Branch instructions
+###############################################################################
+
+joff: reloc  is off [ reloc = inst_next + off * 8; ] { export *:8 reloc; }
+
+:JA joff  is joff & op_alu_jmp_opcode=0x0 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	goto joff;
+}
+
+:JEQ dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0x1 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst==imm) goto joff;
+}
+
+:JEQ dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0x1 & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst==src) goto joff;
+}
+
+:JGT dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0x2 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst>imm) goto joff;
+}
+
+:JGT dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0x2 & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst>src) goto joff;
+}
+
+:JGE dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst>=imm) goto joff;
+}
+
+:JGE dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0x3 & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst>=src) goto joff;
+}
+
+:JLT dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0xa & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst<imm) goto joff;
+}
+
+:JLT dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0xa & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst<src) goto joff;
+}
+
+:JLE dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst<=imm) goto joff;
+}
+
+:JLE dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0xb & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst<=src) goto joff;
+}
+
+:JNE dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst!=imm) goto joff;
+}
+
+:JNE dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0x5 & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst!=src) goto joff;
+}
+
+:JSGT dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst s>imm) goto joff;
+}
+
+:JSGT dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0x6 & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst s>src) goto joff;
+}
+
+:JSGE dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst s>=imm) goto joff;
+}
+
+:JSGE dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0x7 & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst s>=src) goto joff;
+}
+
+:JSLT dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=0 & op_insn_class=0x5 {
+	if (dst s<imm) goto joff;
+}
+
+:JSLT dst, src, joff  is joff & src & dst & op_alu_jmp_opcode=0xc & op_alu_jmp_source=1 & op_insn_class=0x5 {
+	if (dst s<src) goto joff;
+}
+
+:JSLE dst, imm, joff  is imm & joff & dst & op_alu_jmp_opcode=0xd & op_alu_jmp_source=0 & op_insn_class=0x5 {
